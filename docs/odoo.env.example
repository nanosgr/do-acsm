# Archivo de configuración de Odoo para producción
# Copiar a .docker/odoo.env
# cp docs/odoo.env.example .docker/odoo.env

# ====================
# SEGURIDAD (CRÍTICO)
# ====================

# Password del usuario admin de Odoo
# Cambiar por una contraseña segura (mínimo 16 caracteres, letras, números, símbolos)
ADMIN_PASSWORD=CAMBIAR_ESTO_POR_PASSWORD_SEGURO

# Password de la base de datos PostgreSQL
# Debe coincidir con el valor en db-access.env y db-creation.env
PGPASSWORD=CAMBIAR_ESTO_POR_PASSWORD_DB_SEGURO

# ====================
# CONFIGURACIÓN BÁSICA
# ====================

# Modo proxy (necesario para Traefik/HTTPS)
PROXY_MODE=true

# Deshabilitar datos de demostración
WITHOUT_DEMO=all

# Deshabilitar listado de bases de datos (seguridad)
LIST_DB=false

# ====================
# SMTP / EMAIL (Opcional)
# ====================

# Configuración para envío de emails
# Descomentar y configurar según tu proveedor

# Gmail (requiere App Password)
#SMTP_HOST=smtp.gmail.com
#SMTP_PORT=587
#SMTP_USER=tu_email@gmail.com
#SMTP_PASSWORD=tu_app_password
#SMTP_SSL=false
#EMAIL_FROM=tu_email@gmail.com

# Mailgun
#SMTP_HOST=smtp.mailgun.org
#SMTP_PORT=587
#SMTP_USER=postmaster@tu-dominio.mailgun.org
#SMTP_PASSWORD=tu_password
#SMTP_SSL=false
#EMAIL_FROM=noreply@tu-dominio.com

# SendGrid
#SMTP_HOST=smtp.sendgrid.net
#SMTP_PORT=587
#SMTP_USER=apikey
#SMTP_PASSWORD=tu_api_key
#SMTP_SSL=false
#EMAIL_FROM=noreply@tu-dominio.com

# SMTP Custom
#SMTP_HOST=smtp.tu-proveedor.com
#SMTP_PORT=587
#SMTP_USER=tu_usuario
#SMTP_PASSWORD=tu_password
#SMTP_SSL=false
#EMAIL_FROM=noreply@tu-dominio.com

# ====================
# AVANZADO (Opcional)
# ====================

# Límite de memoria (opcional)
#LIMIT_MEMORY_HARD=2684354560
#LIMIT_MEMORY_SOFT=2147483648

# Workers (para alta carga)
#WORKERS=2

# Timeout (segundos)
#LIMIT_TIME_CPU=600
#LIMIT_TIME_REAL=1200

# Logging
#LOG_LEVEL=info
