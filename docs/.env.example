# Ejemplo de archivo .env para Traefik (inverseproxy.yaml)
# Copiar este archivo como .env en el directorio donde ejecutes inverseproxy.yaml
# cp .env.example .env

# Email para Let's Encrypt (obligatorio)
# Let's Encrypt enviará notificaciones de renovación a este email
LETSENCRYPT_EMAIL=admin@aeroclubsanmartin.com.ar

# Opcional: Descomentar para usar servidor de staging de Let's Encrypt (para testing)
# Esto evita llegar al límite de rate limit durante pruebas
# LETSENCRYPT_STAGING=true
